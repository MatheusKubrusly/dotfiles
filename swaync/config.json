{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 15,
  "control-center-margin-bottom": 15,
  "control-center-margin-right": 15,
  "control-center-margin-left": 15,
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-icon-size": 0,
  "notification-body-image-height": 0,
  "notification-body-image-width": 0,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "relative-timestamps": true,
  "control-center-width": 450,
  "control-center-height": 600,
  "notification-window-width": 450,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "nothing",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "0 SYSTEM LOGS FOUND",
  "script-fail-notify": true,
  "scripts": {
    "example-script": {
      "app-name": "example.app.id",
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    },
    "example-action-script": {
      "app-name": "example.app.id",
      "exec": "echo 'Do something actionable!'",
      "urgency": "Normal",
      "run-on": "action"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Normal",
      "app-name": "example.app.id"
    }
  },
  "widgets": [
    "title",
    "dnd",
    "notifications",
    "buttons-grid"
  ],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "title": {
      "text": "SYSTEM_LOGS",
      "clear-all-button": true,
      "button-text": "PURGE_ALL"
    },
    "dnd": {
      "text": "SILENT_PROTOCOL"
    },
    "buttons-grid": {
      "buttons-per-row": 7,
      "actions": [
        {
          "label": "WLAN",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        }
      ]
    }
  }
}
